# このファイルを .env にコピーして使う: cp .env.example .env
# .env は秘密情報を含むためコミットしない（.gitignore 済み）

# ホスト側の公開ポート（他プロジェクトと衝突する場合はここだけ変える）
API_PORT=8002
DB_PORT=5433
FRONT_PORT=5176

# PostgreSQL の接続情報
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo_dev_password
POSTGRES_DB=todo

# JWT の署名鍵（本番では必ず長いランダム値に変える。32バイト以上必須）
# 生成例: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-key-change-me-0123456789abcdef

# CORS で許可するフロントのオリジン（FRONT_PORT と揃える）
FRONTEND_ORIGIN=http://localhost:5176

# フロントが接続する API の URL（API_PORT と揃える）
VITE_API_URL=http://localhost:8002
